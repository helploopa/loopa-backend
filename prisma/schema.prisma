generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model User {
  id                             String        @id @default(uuid())
  email                          String        @unique
  firstName                      String?
  lastName                       String?
  name                           String?
  password                       String
  expoPushToken                  String?
  emailVerified                  Boolean       @default(false)
  emailVerificationToken         String?       @unique
  emailVerificationTokenExpiry   DateTime?
  seller                         Seller?
  orders                         Order[]
  claimedSamples                 Sample[]
  orderReviews                   OrderReview[]
  chatsAsParticipant1            Chat[]        @relation("ChatParticipant1")
  chatsAsParticipant2            Chat[]        @relation("ChatParticipant2")
  sentMessages                   Message[]
  createdAt                      DateTime      @default(now())
  updatedAt                      DateTime      @updatedAt
}

model Seller {
  id                  String    @id @default(uuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id])
  name                String
  description         String
  tagline             String?
  location            String?   // free-form e.g. "Willow Creek, CA"
  categories          String[]
  bio                 String?
  workPhotos          String[]
  businessLicense     String?   // "yes" | "no" | "not_required"
  deliveryRadiusMiles Float?
  samplesPerMonth     Int?
  orderCapDollars     Float?
  publishedAt         DateTime?
  avatarUrl           String?
  coverPhoto          String?
  latitude            Float
  longitude           Float
  city                String?
  state               String?
  pickupDays          String?
  pickupStartTime     String?
  pickupEndTime       String?
  serviceType         String?   // "service" or "product"
  status              String    @default("draft") // draft, review, submitted, active
  workPermit          Boolean   @default(false)
  delivery            Boolean   @default(false)
  products            Product[]
  stories             Story[]
  samples             Sample[]
  orders              Order[]
  businessHours       SellerBusinessHours[]
  features            SellerFeature[]
  media               SellerMedia[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([latitude, longitude])
}

model Product {
  id                String      @id @default(uuid())
  sellerId          String
  seller            Seller      @relation(fields: [sellerId], references: [id])
  title             String
  description       String
  price             Float
  currency          String      @default("USD")
  quantityAvailable Int         @default(1)
  quantityLeft      Int         @default(1) // Keeping for compatibility as requested
  images            String[]
  primaryImage      String?
  imageUrl          String? // Deprecated in favor of primaryImage but keeping for now
  category          String?
  tags              String[]
  badges            String[]
  pickupWindows     Json? // Stores array of pickup windows
  pickupLocation    Json? // Stores location details
  isFavorite        Boolean     @default(false)
  isActive          Boolean     @default(true)  // false = soft-deleted
  deletedAt         DateTime?
  orderItems        OrderItem[]
  samples           Sample[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model SellerMedia {
  id              String   @id @default(uuid())
  sellerId        String
  seller          Seller   @relation(fields: [sellerId], references: [id])
  entityType      String   // seller_avatar | seller_cover | seller_work_photo | product
  entityId        String?  // productId when entityType = "product"
  filename        String
  mimeType        String
  sizeBytes       Int
  storageProvider String   @default("local") // local | s3
  storageKey      String   // local: "/uploads/file.jpg"  s3: "sellers/abc/products/xyz/image.jpg"
  publicUrl       String   // URL served to clients
  isPrimary       Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sellerId, entityType])
  @@index([entityId])
}

model Story {
  id        String   @id @default(uuid())
  sellerId  String
  seller    Seller   @relation(fields: [sellerId], references: [id])
  content   String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  label     String
  icon      String
  isActive  Boolean  @default(true)
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chat {
  id             String    @id @default(uuid())
  orderId        String?
  order          Order?    @relation(fields: [orderId], references: [id])
  participant1Id String
  participant1   User      @relation("ChatParticipant1", fields: [participant1Id], references: [id])
  participant2Id String
  participant2   User      @relation("ChatParticipant2", fields: [participant2Id], references: [id])
  lastMessageAt  DateTime?
  unreadCount1   Int       @default(0) // unread count for participant1
  unreadCount2   Int       @default(0) // unread count for participant2
  messages       Message[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([participant1Id, participant2Id, orderId])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  content   String?
  imageUrl  String?
  type      String   @default("text") // text, image, sample_offer
  readBy    String[] // array of userIds who have read this message
  createdAt DateTime @default(now())
}

model Order {
  id          String        @id @default(uuid())
  orderNumber String        @unique @default(cuid())
  status      String        @default("pending")
  totalAmount Float
  currency    String        @default("USD")
  customerId  String
  customer    User          @relation(fields: [customerId], references: [id])
  sellerId    String
  seller      Seller        @relation(fields: [sellerId], references: [id])
  items           OrderItem[]
  reviews         OrderReview[]
  orderChanges    OrderChange[]
  deliveryHistory OrderDeliveryStatus[]
  chats           Chat[]
  pickupDate      String? // e.g. "03-22-2026"
  pickupTime      String? // e.g. "10:00 - 12:00"
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model OrderItem {
  id         String        @id @default(uuid())
  orderId    String
  order      Order         @relation(fields: [orderId], references: [id])
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  quantity        Int
  price           Float
  pickupDate      String?
  pickupTime      String?
  reviews         OrderReview[]
  orderChanges    OrderChange[]
  deliveryHistory OrderDeliveryStatus[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model Sample {
  id              String    @id @default(uuid())
  sellerId        String
  seller          Seller    @relation(fields: [sellerId], references: [id])
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id])
  status          String    @default("available") // available, claimed, expired
  pickupWindows   Json? // Array of available pickup windows
  expiresAt       DateTime?
  claimedByUserId String?
  claimedByUser   User?     @relation(fields: [claimedByUserId], references: [id])
  claimedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model OrderReview {
  id            String    @id @default(uuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])
  customerId    String
  customer      User      @relation(fields: [customerId], references: [id])
  orderItemId   String
  orderItem     OrderItem @relation(fields: [orderItemId], references: [id])
  comments      String?
  overallRating Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model OrderChange {
  id                 String     @id @default(uuid())
  orderId            String
  order              Order      @relation(fields: [orderId], references: [id])
  orderItemId        String?
  orderItem          OrderItem? @relation(fields: [orderItemId], references: [id])
  changedBy          String // "customer" or "seller"
  previousStatus     String
  newStatus          String
  proposedPickupDate String?
  proposedPickupTime String?
  reason             String?
  comments           String?
  createdAt          DateTime   @default(now())
}

model OrderDeliveryStatus {
  id               String     @id @default(uuid())
  orderId          String
  order            Order      @relation(fields: [orderId], references: [id])
  orderItemId      String?
  orderItem        OrderItem? @relation(fields: [orderItemId], references: [id])
  status           String // IN_PROGRESS, READY_FOR_PICKUP, COMPLETED, CANCELLED
  updatedBy        String // "seller" or "system"
  pickupAddress    String?
  pickupTimeWindow String?
  comments         String?
  createdAt        DateTime   @default(now())
}

model SellerBusinessHours {
  id        String   @id @default(uuid())
  sellerId  String
  seller    Seller   @relation(fields: [sellerId], references: [id])
  dayCode   String   // M=Monday, U=Tuesday, W=Wednesday, T=Thursday, F=Friday, S=Saturday, X=Sunday
  startTime String
  endTime   String
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sellerId, dayCode])
}

model SellerFeature {
  id         String   @id @default(uuid())
  sellerId   String
  seller     Seller   @relation(fields: [sellerId], references: [id])
  featureKey String   // e.g. "sampling", "delivery"
  enabled    Boolean  @default(false)
  config     Json?    // feature-specific config, e.g. { weekly_sample: 10 }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([sellerId, featureKey])
}

